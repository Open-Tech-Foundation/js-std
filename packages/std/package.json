{
  "name": "@opentf/std",
  "version": "0.13.0",
  "description": "An Extensive JavaScript Standard Library.",
  "keywords": [
    "collection",
    "js",
    "ts",
    "utils",
    "utility",
    "string",
    "array",
    "object",
    "timers",
    "types",
    "is",
    "stdlib",
    "number",
    "maths",
    "sleep",
    "clone",
    "async",
    "rgb",
    "hex",
    "shallow",
    "deep",
    "case",
    "assert",
    "replace",
    "diff",
    "range",
    "sort",
    "merge",
    "zero",
    "neg",
    "intersperse"
  ],
  "author": {
    "name": "Thanga Ganapathy",
    "email": "ganapathy888@gmail.com",
    "url": "https://thanga-ganapathy.github.io"
  },
  "license": "MIT",
  "homepage": "https://js-std.pages.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/Open-Tech-Foundation/js-std.git"
  },
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "sideEffects": false,
  "engines": {
    "node": ">=16.20.2"
  },
  "scripts": {
    "build": "bun scripts/build.ts && tsc --emitDeclarationOnly --outDir dist",
    "test": "bun test",
    "test:node": "vitest run",
    "dev": "bun scripts/build.ts --watch",
    "check-types": "tsc --noEmit"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "esbuild": "^0.21.5",
    "typescript": "^5.5.3",
    "vitest": "^4.1.5"
  }
}
