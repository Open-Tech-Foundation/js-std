{
  "name": "@opentf/std",
  "version": "1.0.0-beta.0",
  "description": "An Extensive JavaScript Standard Library.",
  "keywords": [
    "collection",
    "js",
    "ts",
    "utils",
    "utility",
    "string",
    "array",
    "object",
    "timers",
    "types",
    "is",
    "stdlib",
    "number",
    "maths",
    "sleep",
    "clone",
    "async",
    "rgb",
    "hex",
    "shallow",
    "deep",
    "case",
    "assert",
    "replace",
    "diff",
    "range",
    "sort",
    "merge",
    "zero",
    "neg",
    "intersperse"
  ],
  "license": "MIT",
  "homepage": "https://js-std.pages.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Open-Tech-Foundation/js-std.git"
  },
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "sideEffects": false,
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "bun scripts/build.ts",
    "test": "bun test",
    "test:node": "vitest run",
    "dev": "bun scripts/build.ts --watch",
    "check-types": "tsc --noEmit",
    "lint": "biome check ./src",
    "format": "biome format --write ./src"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "esbuild": "^0.28.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
